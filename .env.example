# ============================================================
# Distributed Chat System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=distributed-chat-system
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
NODE_ID=node-1
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://chatuser:chatpass@localhost:5432/chatdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_WS_TOKEN_EXPIRE_MINUTES=5

# --- Security ---
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS_PER_USER=5
WS_MESSAGE_QUEUE_SIZE=100
WS_MAX_MESSAGE_SIZE=65536

# --- Workers ---
OFFLINE_MESSAGE_MAX_RETRIES=5
OFFLINE_MESSAGE_RETRY_BASE_DELAY=5
NOTIFICATION_BATCH_SIZE=50
DEAD_LETTER_RETENTION_DAYS=30

# --- Observability ---
METRICS_ENABLED=true
TRACING_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# --- Encryption (Simplified E2E) ---
RSA_KEY_SIZE=2048
